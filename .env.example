# Optional Shopify Storefront integration (Museum -> add-to-cart -> Shopify checkout redirect)
SHOPIFY_STORE_DOMAIN=your-shop.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=replace_me
# Shopify Storefront API version, e.g. 2025-01 (optional)
SHOPIFY_API_VERSION=2025-01

# Optional public shop URL for “Zum Shop” links (e.g. https://shop.example.com)
NEXT_PUBLIC_SHOP_BASE_URL=

# Optional Gelato API integration
GELATO_API_KEY=replace_me
GELATO_STORE_ID=replace_me
GELATO_PUBLIC_FILE_BASE_URL=https://your-public-site.example.com
GELATO_TEMPLATE_ID=replace_me
GELATO_ASSET_ROUTE_PREFIX=gelato-assets

# Optional: allow linking directly to the myshopify domain if you don't have a custom shop URL
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=

# Optional: where purchase inquiries should go when no Shopify product is linked
# (client-visible for mailto links)
NEXT_PUBLIC_INQUIRY_EMAIL=felix@ipfling.de
